# Copie este arquivo para .env e preencha os valores antes de subir o servidor.

# URL de conexao com o banco de dados SQLite
DATABASE_URL=sqlite:///./database.db

# Chave secreta para assinatura dos tokens JWT
# Em producao, substitua por um valor longo, aleatorio e unico
JWT_SECRET=

# Chave da API do Google Gemini.
# Obrigatoria para o endpoint POST /api/assistente/perguntar.
# Sem ela o endpoint retorna HTTP 503.
# Obtenha em: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
